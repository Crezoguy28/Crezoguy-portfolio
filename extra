<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TiperX — Cinematic Scroll</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@600;700&family=Cabinet+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --ink: #0d0d1a;
  --purple: #5b4bdb;
  --purple-soft: #7c6ef5;
  --cream: #f9f8ff;
  --muted: #9090aa;
}

html { scroll-behavior: smooth; }

body {
  background: #000;
  color: #fff;
  font-family: 'Cabinet Grotesk', sans-serif;
  overflow-x: hidden;
}

/* ═══════════════════════════════
   HERO INTRO
═══════════════════════════════ */
.hero {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: radial-gradient(ellipse 100% 80% at 50% 0%, #1a0a3e 0%, #000 70%);
  position: relative;
  overflow: hidden;
  text-align: center;
  padding: 40px;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: 
    radial-gradient(circle 600px at 20% 80%, rgba(91,75,219,0.12) 0%, transparent 70%),
    radial-gradient(circle 400px at 80% 20%, rgba(30,93,232,0.10) 0%, transparent 70%);
}

.hero-eyebrow {
  font-size: 11px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--purple-soft);
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 0.8s 0.3s forwards;
}

.hero-title {
  font-family: 'Clash Display', 'Cabinet Grotesk', sans-serif;
  font-size: clamp(44px, 8vw, 96px);
  font-weight: 700;
  line-height: 1.0;
  letter-spacing: -0.03em;
  background: linear-gradient(135deg, #fff 0%, #c4b8ff 50%, #7c6ef5 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 24px;
  opacity: 0;
  animation: fadeUp 0.8s 0.5s forwards;
}

.hero-sub {
  font-size: clamp(15px, 2vw, 19px);
  color: rgba(255,255,255,0.45);
  max-width: 520px;
  line-height: 1.7;
  margin-bottom: 48px;
  opacity: 0;
  animation: fadeUp 0.8s 0.7s forwards;
}

.scroll-cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  opacity: 0;
  animation: fadeUp 0.8s 1.1s forwards;
  cursor: pointer;
}

.scroll-cta span {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
}

.scroll-line {
  width: 1px;
  height: 50px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.15), var(--purple));
  position: relative;
  overflow: hidden;
}

.scroll-line::after {
  content: '';
  position: absolute;
  top: -100%;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, transparent, #fff);
  animation: scanline 1.8s ease-in-out infinite;
}

@keyframes scanline { 0% { top: -100% } 100% { top: 200% } }
@keyframes fadeUp { from { opacity:0; transform:translateY(24px) } to { opacity:1; transform:translateY(0) } }

/* ═══════════════════════════════
   CINEMATIC SCROLL SECTION
═══════════════════════════════ */
.cinematic-section {
  position: relative;
  /* tall enough for 17 frames with breathing room */
  height: 550vh;
  background: #000;
}

.cinematic-sticky {
  position: sticky;
  top: 0;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* Dark ambient bg that subtly shifts */
.ambient-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 120% 100% at 50% 50%, #0d0818 0%, #000 100%);
  transition: background 0.5s;
}

/* grain overlay */
.ambient-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  opacity: 0.5;
}

/* The frame canvas */
.frame-canvas {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.device-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  opacity: 0;
  transition: none;
  user-select: none;
  pointer-events: none;
  will-change: opacity, transform;
}

.device-img.active {
  opacity: 1;
}

/* Progress dots */
.frame-dots {
  position: fixed;
  right: 28px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 10px;
  z-index: 100;
  opacity: 0;
  transition: opacity 0.4s;
}

.frame-dots.visible { opacity: 1; }

.fdot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transition: all 0.3s;
  cursor: pointer;
}

.fdot.on {
  background: var(--purple-soft);
  transform: scale(1.8);
  box-shadow: 0 0 8px rgba(124,110,245,0.6);
}

/* Frame counter */
.frame-counter {
  position: fixed;
  left: 36px;
  bottom: 36px;
  z-index: 100;
  font-size: 11px;
  letter-spacing: 0.2em;
  color: rgba(255,255,255,0.25);
  opacity: 0;
  transition: opacity 0.4s;
  font-variant-numeric: tabular-nums;
}

.frame-counter.visible { opacity: 1; }

.frame-counter b {
  color: rgba(255,255,255,0.6);
  font-size: 15px;
  font-weight: 700;
}

/* Progress bar */
.progress-track {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: rgba(255,255,255,0.06);
  z-index: 200;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(to right, var(--purple), var(--purple-soft));
  width: 0%;
  transition: width 0.05s linear;
}

/* ═══════════════════════════════
   OUTRO
═══════════════════════════════ */
.outro {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: radial-gradient(ellipse 100% 80% at 50% 100%, #1a0a3e 0%, #000 70%);
  text-align: center;
  padding: 80px 40px;
  position: relative;
}

.outro-title {
  font-family: 'Clash Display', 'Cabinet Grotesk', sans-serif;
  font-size: clamp(36px, 6vw, 72px);
  font-weight: 700;
  letter-spacing: -0.03em;
  background: linear-gradient(135deg, #fff 0%, #c4b8ff 60%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 20px;
}

.outro-sub {
  color: rgba(255,255,255,0.4);
  font-size: 18px;
  margin-bottom: 48px;
  max-width: 400px;
}

.cta-pill {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--purple);
  color: #fff;
  padding: 16px 36px;
  border-radius: 50px;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: 0.02em;
  cursor: pointer;
  transition: all 0.2s;
  box-shadow: 0 0 40px rgba(91,75,219,0.4);
}

.cta-pill:hover {
  background: var(--purple-soft);
  transform: translateY(-2px);
  box-shadow: 0 8px 40px rgba(124,110,245,0.5);
}

/* cinematic letterbox bars */
.letterbox-top, .letterbox-bottom {
  position: fixed;
  left: 0; right: 0;
  height: 0px;
  background: #000;
  z-index: 150;
  transition: height 0.6s cubic-bezier(0.16,1,0.3,1);
}

.letterbox-top { top: 0; }
.letterbox-bottom { bottom: 0; }

body.cinematic-mode .letterbox-top,
body.cinematic-mode .letterbox-bottom {
  height: 40px;
}

@media (max-width: 768px) {
  body.cinematic-mode .letterbox-top,
  body.cinematic-mode .letterbox-bottom { height: 20px; }
}
</style>
</head>
<body>

<div class="letterbox-top"></div>
<div class="letterbox-bottom"></div>

<div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>

<!-- HERO -->
<section class="hero" id="heroSection">
  <div class="hero-eyebrow">Introducing TiperX</div>
  <h1 class="hero-title">Your Trading<br>Hub</h1>
  <p class="hero-sub">Track portfolios, join trading groups, and access top signals — smarter trading starts here.</p>
  <div class="scroll-cta" onclick="document.getElementById('cinematic').scrollIntoView({behavior:'smooth'})">
    <span>Scroll to explore</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- CINEMATIC SCROLL -->
<section class="cinematic-section" id="cinematic">
  <div class="cinematic-sticky" id="stickyPane">
    <div class="ambient-bg" id="ambientBg"></div>
    <div class="frame-canvas" id="frameCanvas">
      <!-- images injected by JS -->
    </div>
  </div>
</section>

<!-- OUTRO -->
<section class="outro">
  <div class="outro-title">All in One Place</div>
  <p class="outro-sub">Connect Telegram, WhatsApp, Kwant and more — all from one powerful hub.</p>
  <div class="cta-pill">Get Started →</div>
</section>

<!-- Frame nav dots -->
<div class="frame-dots" id="frameDots"></div>
<div class="frame-counter" id="frameCounter"><b>01</b> / 17</div>

<script>
const FRAMES = [
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,"
];

const TOTAL = FRAMES.length;
const canvas = document.getElementById('frameCanvas');
const dotsEl = document.getElementById('frameDots');
const counterEl = document.getElementById('frameCounter');
const progressFill = document.getElementById('progressFill');
const cinematic = document.getElementById('cinematic');
const ambientBg = document.getElementById('ambientBg');

// Ambient color hints per frame cluster
const ambients = [
  'radial-gradient(ellipse 120% 100% at 50% 30%, #0d0818 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #0d0818 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #0d0818 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #100a20 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #100a20 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #120b22 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #130c25 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #140d28 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #150d2a 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #160e2c 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #160e2e 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #170f30 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #181030 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #191030 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #1a1132 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #1a1135 0%, #000 100%)',
  'radial-gradient(ellipse 120% 100% at 50% 30%, #1b1238 0%, #000 100%)',
];

// Build img elements
const imgs = FRAMES.map((src, i) => {
  const img = document.createElement('img');
  img.src = src;
  img.className = 'device-img' + (i === 0 ? ' active' : '');
  img.draggable = false;
  canvas.appendChild(img);
  return img;
});

// Build dots
FRAMES.forEach((_, i) => {
  const d = document.createElement('div');
  d.className = 'fdot' + (i === 0 ? ' on' : '');
  d.title = `Frame ${i+1}`;
  d.addEventListener('click', () => jumpToFrame(i));
  dotsEl.appendChild(d);
});

const dots = dotsEl.querySelectorAll('.fdot');

let currentFrame = 0;

function setFrame(idx) {
  idx = Math.max(0, Math.min(TOTAL - 1, idx));
  if (idx === currentFrame) return;
  
  imgs[currentFrame].classList.remove('active');
  dots[currentFrame].classList.remove('on');
  
  currentFrame = idx;
  
  imgs[currentFrame].classList.add('active');
  dots[currentFrame].classList.add('on');
  ambientBg.style.background = ambients[currentFrame];
  
  const num = String(currentFrame + 1).padStart(2, '0');
  counterEl.innerHTML = `<b>${num}</b> / ${TOTAL}`;
}

function jumpToFrame(idx) {
  const rect = cinematic.getBoundingClientRect();
  const totalScroll = cinematic.offsetHeight - window.innerHeight;
  const target = cinematic.offsetTop + (idx / (TOTAL - 1)) * totalScroll;
  window.scrollTo({ top: target, behavior: 'smooth' });
}

// Scroll logic
function onScroll() {
  const rect = cinematic.getBoundingClientRect();
  const totalScroll = cinematic.offsetHeight - window.innerHeight;
  const scrolled = -rect.top;
  const rawProgress = Math.max(0, Math.min(1, scrolled / totalScroll));
  
  // In cinematic zone?
  const inZone = scrolled > -window.innerHeight * 0.5 && scrolled < totalScroll + window.innerHeight * 0.5;
  dotsEl.classList.toggle('visible', inZone);
  counterEl.classList.toggle('visible', inZone);
  document.body.classList.toggle('cinematic-mode', inZone && rawProgress > 0 && rawProgress < 1);
  
  // Frame index
  const frameIdx = Math.round(rawProgress * (TOTAL - 1));
  setFrame(frameIdx);
  
  // Global progress
  const globalMax = document.body.scrollHeight - window.innerHeight;
  const globalP = window.scrollY / globalMax;
  progressFill.style.width = (globalP * 100) + '%';
}

window.addEventListener('scroll', onScroll, { passive: true });
onScroll();
</script>
</body>
</html>
